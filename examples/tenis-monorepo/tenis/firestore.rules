rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /clubs/{clubId} {
      // Lectura permitida solo a usuarios autenticados (datos no sensibles en UI).
      // Escrituras directas desde el cliente están bloqueadas: solo el backend (Admin SDK) muta.
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
