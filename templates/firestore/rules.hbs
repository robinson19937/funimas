rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
{{#each collections}}
    match /{{this}}/{documentId} {
      // Lecturas y escrituras directas desde el cliente bloqueadas.
      // Solo el backend (Admin SDK vía Netlify Functions) accede a Firestore.
      allow read, create, update, delete: if false;
    }

{{/each}}
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
